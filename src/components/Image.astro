---
// Usage: <Image src="/images/example.svg" caption="وصف الصورة" alt="نص بديل" />
export interface Props {
  src: string;
  caption?: string;
  alt?: string;
}
const { src, caption, alt = caption || '' } = Astro.props;
---
<figure class="article-image">
  <img src={src} alt={alt} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
